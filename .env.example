PROJECT_NAME="MoveMate API"
VERSION="0.1.0"

# Database (PostgreSQL)
DATABASE_URL="postgresql+psycopg://user:password@localhost:5432/movemate"

# JWT — set SECRET_KEY to a long random string in production
SECRET_KEY="change-me-in-production-use-openssl-rand-hex-32"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7


# Chapa payment
CHAPA_SECRET_KEY="CHAPA_SECRET_KEY_HERE"
CHAPA_BASE_URL="https://api.chapa.co/v1"
CHAPA_CALLBACK_URL="http://localhost:8000/api/v1/tickets/callback"
CHAPA_RETURN_URL="http://localhost:8000/success"

# Optional Hugging Face-hosted ETA model (downloaded on app startup when configured)
ETA_MODEL_PATH="ETA_datasets/eta_model.joblib"
ETA_MODEL_HF_REPO_ID=""
ETA_MODEL_HF_FILENAME="eta_model.joblib"
ETA_MODEL_HF_REVISION="main"
HUGGINGFACE_HUB_TOKEN=""

# Optional bootstrap superadmin (created on app startup if both are set)
SUPERADMIN_EMAIL="superadmin@movemate.com"
SUPERADMIN_PASSWORD=""
SUPERADMIN_FULL_NAME="Super Admin"
SUPERADMIN_PHONE_NUMBER="N/A"

