PROJECT_NAME="MoveMate API"
VERSION="0.1.0"

# Database (PostgreSQL)
DATABASE_URL="postgresql+psycopg://user:password@localhost:5432/movemate"

# JWT — set SECRET_KEY to a long random string in production
SECRET_KEY="change-me-in-production-use-openssl-rand-hex-32"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

